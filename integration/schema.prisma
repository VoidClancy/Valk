datasource db {
    provider = "sqlite"
}

enum UserRole {
    ADMIN
    STUDENT @map("student")
    TEACHER

    @@map("user_roles")
}

model User {
    id           String    @id @default(cuid())
    email        String    @unique
    phoneNum     String    @unique
    password     String?
    role         UserRole  @default(STUDENT)
    roleOptional UserRole?
    profile      Profile?
    posts        Post[]
    comments     Comment[]

    referredById String?
    referredBy   User?   @relation("UserReferrals", fields: [referredById], references: [id])
    referrals    User[]  @relation("UserReferrals")

    @@unique([email, phoneNum], name: "emailPhone")
}

model Profile {
    id        String   @id @default(cuid())
    bio       String?
    userId    String   @unique
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())
}

model Post {
    id         String           @id @default(cuid())
    title      String
    content    String?
    published  Boolean          @default(false)
    authorId   String
    author     User             @relation(fields: [authorId], references: [id])
    comments   Comment[]
    categories CategoryToPost[]
}

model Comment {
    id       String @id @default(cuid())
    textify  Int
    dummy3   String
    dummy1   Int
    dummy2   String
    postId   String
    post     Post   @relation(fields: [postId], references: [id])
    authorId String
    author   User   @relation(fields: [authorId], references: [id])
    meta     Json?
}

model Category {
    id    Int              @id @default(autoincrement())
    name  String           @unique
    posts CategoryToPost[]
}

model CategoryToPost {
    postId     String
    categoryId Int
    post       Post     @relation(fields: [postId], references: [id])
    category   Category @relation(fields: [categoryId], references: [id])

    @@id([postId, categoryId])
}

model DefaultsTest {
    uuid4      String   @id @default(uuid(4))
    uuid7      String   @default(uuid(7))
    uuidNoArgs String   @default(uuid())
    cuid1      String   @default(cuid(1))
    cuid2      String   @default(cuid(2))
    cuidNoArgs String   @default(cuid())
    ulid       String   @default(ulid())
    nanoid     String   @default(nanoid())
    now        DateTime @default(now())
}

model AllFieldsSoFar {
    id Int @id @default(autoincrement())

    // String
    stringReq     String
    stringOpt     String?
    stringDefault String  @default("default")
    stringVarchar String
    stringChar    String

    // Default function variants
    cuidDefault   String @default(cuid())
    cuid1Default  String @default(cuid(1))
    cuid2Default  String @default(cuid(2))
    uuidDefault   String @default(uuid())
    uuid4Default  String @default(uuid(4))
    uuid7Default  String @default(uuid(7))
    ulidDefault   String @default(ulid())
    nanoidDefault String @default(nanoid())
    uuidDb        String

    // Int
    intReq     Int
    intOpt     Int?
    intDefault Int  @default(42)
    smallInt   Int
    tinyInt    Int

    // BigInt
    bigIntReq BigInt
    bigIntOpt BigInt?

    // Float
    floatReq Float
    floatOpt Float?

    // Decimal
    decimalReq     Decimal
    decimalOpt     Decimal?
    decimalPrecise Decimal

    // Boolean
    boolReq     Boolean
    boolOpt     Boolean?
    boolDefault Boolean  @default(false)

    // DateTime
    dateTimeReq     DateTime
    dateTimeOpt     DateTime?
    dateTimeDefault DateTime  @default(now())
    updatedAt       DateTime  @updatedAt
    dateTimeTz      DateTime

    // Json
    jsonReq Json
    jsonOpt Json?

    // Bytes
    bytesReq Bytes
    bytesOpt Bytes?
}
