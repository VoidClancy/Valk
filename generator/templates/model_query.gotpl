	}
	orderByClause := formatOrderBySQL(d.client.dialect, params.OrderBy, {{ lowercase .Model.Name }}PKCols, {{ lowercase .Model.Name }}UniqueCols, isCursorQuery, params.Take)
	returningCols := select{{ .Model.Name }}Cols(selects, omits)

	results, err := d.queryMany(ctx, whereClause, orderByClause, vals, returningCols, params.Take, params.Skip)
	if err != nil || len(results) == 0 {
