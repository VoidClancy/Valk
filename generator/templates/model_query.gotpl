func (d *{{ .Model.Name }}Delegate) runFindMany(
	ctx context.Context,
	params QueryParams[{{ .Model.Name }}],
	selects *{{ .Model.Name }}Select,
	omits *{{ .Model.Name }}Omit,
) ([]*{{ .Model.Name }}, error) {
	for _, pr := range params.Where {
		if pr != nil {
			if err := pr.Validate(); err != nil {
				return nil, err
			}
		}
	}
	whereClause, vals := CompilePredicates(d.client.dialect, params.Where)
	if whereClause != "" {
		whereClause = " WHERE " + whereClause
	}
	returningCols := select{{ .Model.Name }}Cols(selects, omits)

	var results []*{{ .Model.Name }}
	var err error
	if selects.hasAnyRelation() {
		err = d.client.transaction(ctx, func(txQ *Queries) error {
			var err error
			results, err = txQ.{{ .Model.Name }}.queryMany(ctx, whereClause, vals, returningCols, params.Take, params.Skip)
			if err != nil {
				return err
			}
			if len(results) == 0 {
				return nil
			}
			return txQ.{{ .Model.Name }}.loadRelations(ctx, results, selects)
		})
	} else {
		results, err = d.queryMany(ctx, whereClause, vals, returningCols, params.Take, params.Skip)
	}
