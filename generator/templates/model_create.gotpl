	}
			{{- else }}
	if s.{{ $fieldName }} != nil {
		m["{{ $col }}"] = {{ hstoreExpr $field.GoType (printf "*s.%s" $fieldName) }}
	} else {
		m["{{ $col }}"] = rawDefault{}
	}
			{{- end }}
		{{- else if ne $field.Default nil }}
	if s.{{ $fieldName }} != nil {
		m["{{ $col }}"] = {{ hstoreExpr $field.GoType (printf "*s.%s" $fieldName) }}
	} else {
		m["{{ $col }}"] = rawDefault{}
