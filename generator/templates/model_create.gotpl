func partition{{ .Model.Name }}Inputs(dialect Dialect, inputs []*{{ .Model.Name }}Create) [][]*{{ .Model.Name }}Create {
	if !dialect.SupportsBulkInsert {
		result := make([][]*{{ .Model.Name }}Create, len(inputs))
		for i, input := range inputs {
			result[i] = []*{{ .Model.Name }}Create{input}
		}
		return result
	}

	if !dialect.SupportsDefaultKeyword {
		groups := make(map[uint64][]*{{ .Model.Name }}Create)
		var masks []uint64
		for _, input := range inputs {
			mask := input.colMask()
			if _, exists := groups[mask]; !exists {
				masks = append(masks, mask)
			}
			groups[mask] = append(groups[mask], input)
		}
		result := make([][]*{{ .Model.Name }}Create, len(masks))
		for i, mask := range masks {
			result[i] = groups[mask]
		}
		return result
	}

	return [][]*{{ .Model.Name }}Create{inputs}
}

func (d *{{ .Model.Name }}Delegate) executeCreate(ctx context.Context, assignments []FieldAssignment, selects *{{ .Model.Name }}Select, omits *{{ .Model.Name }}Omit, conflictTarget UniqueConstraintTarget, conflictAction *ConflictAction) (*{{ .Model.Name }}, error) {
