func (d *{{ .Model.Name }}Delegate) CreateManyAndReturn(inputs []{{ .Model.Name }}Create) *CreateManyAndReturnBuilder[{{ .Model.Name }}, {{ .Model.Name }}Create, {{ .Model.Name }}Select, {{ .Model.Name }}Omit] {
