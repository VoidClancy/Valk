func (q *Queries) execute{{ .Model.Name }}Create(ctx context.Context, assignments []FieldAssignment, selects *{{ .Model.Name }}Select, omits *{{ .Model.Name }}Omit, conflictTarget UniqueConstraintTarget, conflictAction *ConflictAction) (*{{ .Model.Name }}, error) {
	input := assignmentsTo{{ .Model.Name }}Create(assignments)

	if q.{{ .Model.Name }}.beforeCreate != nil {
		if err := q.{{ .Model.Name }}.beforeCreate(ctx, &input); err != nil {
			return nil, err
		}
	}

	if err := validate{{ .Model.Name }}Create(assignments); err != nil {
		return nil, err
	}

	rowMap := input.ToRowMap()
	cols, vals := mapToColsVals(rowMap, {{ .Model.Name }}ColOrder)

	returningCols := q.select{{ .Model.Name }}Cols(selects, omits)

	scanFunc := func(res *{{ .Model.Name }}, cols []string) []any {
		return res.ScanFields(cols)
	}

	pkCols := []string{
		{{- if .Model.CompositePK }}
			{{- range $col := .Model.CompositePK }}
				"{{ $col }}",
			{{- end }}
		{{- else }}
			{{- range $field := .Model.ScalarFields }}
				{{- if $field.IsID }}
					"{{ $field.EffectiveColName }}",
				{{- end }}
			{{- end }}
		{{- end }}
	}

	hasRelations := selects.hasAnyRelation()

	var res *{{ .Model.Name }}
	var err error
	if hasRelations {
		err = q.transaction(ctx, func(txQ *Queries) error {
			var err error
			res, err = executeInsert(ctx, txQ, "{{ .Model.EffectiveTableName }}", cols, vals, returningCols, pkCols, scanFunc, conflictTarget, conflictAction)
			if err != nil {
				return err
			}
			return txQ.load{{ .Model.Name }}Relations(ctx, []*{{ .Model.Name }}{res}, selects)
		})
	} else {
		res, err = executeInsert(ctx, q, "{{ .Model.EffectiveTableName }}", cols, vals, returningCols, pkCols, scanFunc, conflictTarget, conflictAction)
	}
	if err != nil {
		return nil, err
	}

	if q.{{ .Model.Name }}.afterCreate != nil {
		if err := q.{{ .Model.Name }}.afterCreate(ctx, []*{{ .Model.Name }}{res}); err != nil {
			return nil, err
		}
	}

	return res, nil
}

