			var res *{{ .Model.Name }}
			err = d.client.transaction(ctx, func(txQ *Queries) error {
				var err error
				res, err = txQ.{{ .Model.Name }}.runCreate(ctx, cols, vals, returningCols, {{ lowercase .Model.Name }}PKCols, conflictTarget, conflictAction)
				if err != nil {
					return err
