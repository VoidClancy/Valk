	m := make(map[string]any)
	{{- range $field := .Model.ScalarFields }}
		{{- if $field.EnumRef }}
			{{- if $field.IsArray }}
				if input.{{ capitalize $field.Name }} != nil {
					m["{{ $field.EffectiveColName }}"] = input.{{ capitalize $field.Name }}
