	if err != nil {
		return nil, err
	}

	cols, vals := input.ToColsVals()
	returningCols := select{{ .Model.Name }}Cols(selects, omits)

	if len(d.extensions) == 0 {
		hasRelations := selects.hasAnyRelation()
