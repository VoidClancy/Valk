package {{ .PackageName }}

import (
	"context"
	{{- if hasJsonField .Model }}
	"encoding/json"
	{{- end }}
	"fmt"
	{{- if hasNetField .Model }}
	"net"
	{{- end }}
	"slices"
	{{- if hasStringField .Model }}
	"strings"
	{{- end }}
	{{- if hasTimeField .Model }}
	"time"
	{{- end }}
	{{- if hasStringField .Model }}
	"unicode/utf8"
	{{- end }}
)

