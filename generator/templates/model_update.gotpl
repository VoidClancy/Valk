	*UpdateBuilder[{{ .Model.Name }}, {{ .Model.Name }}Select, {{ .Model.Name }}Omit]
}

type {{ .Model.Name }}UpdateManyBuilder struct {
	*UpdateManyBuilder[{{ .Model.Name }}]
}

type {{ .Model.Name }}UpdateManyAndReturnBuilder struct {
	*UpdateManyAndReturnBuilder[{{ .Model.Name }}, {{ .Model.Name }}Select, {{ .Model.Name }}Omit]
}

{{ range $field := .Model.ScalarFields -}}
{{- $fieldType := trimPrefix $field.GoType "*" -}}
