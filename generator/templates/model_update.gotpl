func (b *{{ $.Model.Name }}UpdateBuilder) Assignments(assignments ...FieldAssignmentOf[{{ .Model.Name }}]) *{{ $.Model.Name }}UpdateBuilder {
	for _, a := range assignments {
		b.assignments = append(b.assignments, FieldAssignment{Col: a.Col, Val: a.Val})
	}
	return b
}

