func (d *{{ .Model.Name }}Delegate) Update(where UniquePredicate[{{ .Model.Name }}], additional ...PredicateOf[{{ .Model.Name }}]) *{{ .Model.Name }}UpdateBuilder {
	return &{{ .Model.Name }}UpdateBuilder{
		UpdateBuilder: &UpdateBuilder[{{ .Model.Name }}, {{ .Model.Name }}Select, {{ .Model.Name }}Omit]{
			where:      where,
			additional: additional,
			execFunc:   d.executeUpdate,
		},
	}
}

