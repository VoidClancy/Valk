func (m *{{ .Model.Name }}) ScanFields(cols []string) []any {
	targets := make([]any, len(cols))
	for i, col := range cols {
		switch col {
		{{- range $field := .Model.ScalarFields }}
		case "{{ $field.EffectiveColName }}":
			{{- if eq (trimPrefix $field.GoType "*") "map[string]*string" }}
			targets[i] = HstoreScan{P: &m.{{ capitalize $field.Name }}}
			{{- else }}
			targets[i] = &m.{{ capitalize $field.Name }}
			{{- end }}
		{{- end }}
		}
	}
	return targets
}

var {{ lowercase .Model.Name }}DefaultCols = []string{
	{{- range $field := .Model.ScalarFields }}
	"{{ $field.EffectiveColName }}",
	{{- end }}
}

var {{ lowercase .Model.Name }}PKCols = []string{
	{{- if .Model.CompositePK }}
		{{- range $col := .Model.CompositePK }}
	"{{ $col }}",
		{{- end }}
	{{- else }}
		{{- range $field := .Model.ScalarFields }}
			{{- if $field.IsID }}
	"{{ $field.EffectiveColName }}",
			{{- end }}
		{{- end }}
	{{- end }}
}

var {{ lowercase .Model.Name }}UniqueCols = []string{
	{{- range $field := .Model.ScalarFields }}
		{{- if or $field.IsID $field.IsUnique }}
	"{{ $field.EffectiveColName }}",
		{{- end }}
	{{- end }}
}

func select{{ .Model.Name }}Cols(selects *{{ .Model.Name }}Select, omits *{{ .Model.Name }}Omit, forceCols ...string) []string {
	if selects == nil && omits == nil && len(forceCols) == 0 {
		return {{ lowercase .Model.Name }}DefaultCols
	}

	anySelected := selects != nil && ({{ range $i, $f := .Model.ScalarFields }}{{ if $i }} || {{ end }}selects.{{ capitalize $f.Name }}{{ end }}{{ range .Model.RelationFields }} || selects.{{ capitalize .Name }} != nil{{ end }})

	specs := []colSpec{
		{{- range $field := .Model.ScalarFields }}
		{"{{ $field.EffectiveColName }}", selects != nil && selects.{{ capitalize $field.Name }}, omits != nil && omits.{{ capitalize $field.Name }},
			{{- if $field.IsID }} selects != nil && selects.hasAnyRelation(){{ else }}
			{{- $relName := fkForRelation $.Model $field }}
			{{- if ne $relName "" }} selects != nil && selects.{{ capitalize $relName }} != nil{{ else }} false{{ end }}{{ end }}},
		{{- end }}
	}

	cols := computeCols(specs, selects != nil, anySelected)

	for _, f := range forceCols {
		if !slices.Contains(cols, f) {
			cols = append(cols, f)
		}
	}

	return cols
}





